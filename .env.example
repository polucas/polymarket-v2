# API Keys
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxx
TWITTER_API_KEY=xxxxxxxxxxxxxxxxxx
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# Optional: Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Environment: "paper" or "live"
ENVIRONMENT=paper

# Database
DB_PATH=data/predictor.db

# Logging
LOG_LEVEL=INFO

# Grok model
GROK_MODEL=grok-4.20-experimental-beta-0304-reasoning

# RSS Polling
RSS_POLL_INTERVAL_SECONDS=30

# Tier 1 Config
TIER1_SCAN_INTERVAL_MINUTES=15
TIER1_MIN_EDGE=0.03
TIER1_DAILY_CAP=5
TIER1_FEE_RATE=0.0
MARKET_FETCH_LIMIT=200
TIER1_EXECUTION_TYPE=maker

# Tier 2 Config
TIER2_SCAN_INTERVAL_MINUTES=3
TIER2_MIN_EDGE=0.05
TIER2_DAILY_CAP=3
TIER2_FEE_RATE=0.04
TIER2_EXECUTION_TYPE=maker

# Early Exit
TAKE_PROFIT_ROI=0.20
STOP_LOSS_ROI=-0.15
EARLY_EXIT_ENABLED=true

# Monk Mode
DAILY_LOSS_LIMIT_PCT=0.05
WEEKLY_LOSS_LIMIT_PCT=0.10
CONSECUTIVE_LOSS_COOLDOWN=3
COOLDOWN_DURATION_HOURS=2.0
DAILY_API_BUDGET_USD=15.0
MAX_POSITION_PCT=0.08
MAX_TOTAL_EXPOSURE_PCT=0.30
KELLY_FRACTION=0.25
MAX_CLUSTER_EXPOSURE_PCT=0.12

# Bankroll
INITIAL_BANKROLL=2000.0
